{
  "name": "guided-reader",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "graphql:generate": "graphql-codegen --config codegen.ts",
    "lint": "npx eslint",
    "pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json}\"",
    "preview": "cross-env NODE_ENV=production tsx --loader ./css-loader.mjs server.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@graphql-codegen/cli": "6.0.1",
    "@graphql-codegen/client-preset": "5.1.1",
    "@graphql-codegen/typescript": "^5.0.2",
    "@graphql-codegen/typescript-operations": "^5.0.2",
    "@types/node": "^25.8.0",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.3",
    "rollup-plugin-visualizer": "^6.0.11",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.45.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/http-proxy": "^11.5.0",
    "@fastify/middie": "^9.3.2",
    "@fastify/static": "^9.1.3",
    "@heroicons/react": "^2.2.0",
    "@posthog/react": "^1.9.0",
    "@sun/api": "^0.2.0",
    "@sun/components": "^0.10.4",
    "@sun/events": "^0.1.0",
    "@sun/shared": "^0.2.11",
    "@sun/ssr": "^0.5.4",
    "@sun/themes": "^0.2.8",
    "@sun/utils": "^0.1.6",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.9.0",
    "i18next": "^25.0.0",
    "lucide-react": "^0.554.0",
    "posthog-node": "^5.21.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "^15.4.1",
    "react-router-dom": "^6.22.0",
    "sirv": "^3.0.1"
  }
}
